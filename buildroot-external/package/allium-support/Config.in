menu "Allium"

config BR2_PACKAGE_ALLIUM_SP
	bool "Allium stack for RG35xxSP"
	depends on BR2_aarch64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_SDL2_IMAGE
	select BR2_PACKAGE_LIBPNG
	select BR2_PACKAGE_SDL2_TTF
	select BR2_PACKAGE_FREETYPE
	select BR2_PACKAGE_ALSA_LIB
	select BR2_PACKAGE_ALSA_UTILS
	select BR2_PACKAGE_ALSA_UTILS_AMIXER
	select BR2_PACKAGE_ALSA_UTILS_ALSACTL
	select BR2_PACKAGE_ZLIB
	select BR2_PACKAGE_LZ4
	select BR2_PACKAGE_DBUS
	select BR2_PACKAGE_WPA_SUPPLICANT
	select BR2_PACKAGE_WPA_SUPPLICANT_NL80211
	select BR2_PACKAGE_READLINE
	select BR2_PACKAGE_BLUEZ5_UTILS
	select BR2_PACKAGE_BLUEZ5_UTILS_TOOLS
	select BR2_PACKAGE_BLUEZ5_UTILS_PLUGINS_AUDIO
	select BR2_PACKAGE_BLUEZ5_UTILS_PLUGINS_HID
	select BR2_PACKAGE_BLUEZ_ALSA
	select BR2_PACKAGE_ALLIUM
	help
	  Enable the Allium package set for Anbernic RG35xxSP.

if BR2_PACKAGE_ALLIUM_SP

source "$BR2_EXTERNAL_ALLIUM_EXTERNAL_PATH/package/bootsplash/Config.in"
source "$BR2_EXTERNAL_ALLIUM_EXTERNAL_PATH/package/allium/Config.in"
source "$BR2_EXTERNAL_ALLIUM_EXTERNAL_PATH/package/remotectl/Config.in"

endif

endmenu
