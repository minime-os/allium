#!/bin/sh

# Buildroot image intentionally runs without a full network manager/resolvconf
# stack. This helper backfills /run/resolv.conf during early boot if DHCP has
# not populated nameservers yet, then exits once a nameserver appears.
# Keep it bounded and optional (RESOLV_DISABLE_HELPER=1) for troubleshooting.

PATH="/usr/sbin:/sbin:/usr/bin:/bin"

PIDFILE="/var/run/resolv-helper.pid"
RESOLV_CONF="/run/resolv.conf"
WAIT_SECS="${RESOLV_WAIT_SECS:-60}"
SLEEP_SECS="${RESOLV_WAIT_INTERVAL:-2}"
FALLBACK_DNS="${RESOLV_FALLBACK_DNS:-1.1.1.1 8.8.8.8}"

has_nameserver() {
	[ -f "$RESOLV_CONF" ] && grep -qE '^[[:space:]]*nameserver[[:space:]]+[0-9]+' "$RESOLV_CONF"
}

default_gateway() {
	ip route 2>/dev/null | awk '/^default / {print $3; exit}'
}

write_resolv() {
	gw="$1"
	tmp="${RESOLV_CONF}.tmp"
	mkdir -p /run
	{
		echo "# generated by S41resolv"
		[ -n "$gw" ] && echo "nameserver $gw"
		for ns in $FALLBACK_DNS; do
			[ -n "$gw" ] && [ "$ns" = "$gw" ] && continue
			echo "nameserver $ns"
		done
	} > "$tmp" || return 1
	mv "$tmp" "$RESOLV_CONF" || { rm -f "$tmp"; return 1; }
	return 0
}

spawn_helper() {
	[ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE" 2>/dev/null)" >/dev/null 2>&1 || true
	(
		left="$WAIT_SECS"
		while [ "$left" -gt 0 ]; do
			if has_nameserver; then
				rm -f "$PIDFILE"
				exit 0
			fi
			gw="$(default_gateway 2>/dev/null || true)"
			if [ -n "$gw" ]; then
				write_resolv "$gw" && { rm -f "$PIDFILE"; exit 0; }
			fi
			sleep "$SLEEP_SECS"
			left=$((left - SLEEP_SECS))
		done
		rm -f "$PIDFILE"
		exit 0
	) >/dev/null 2>&1 &
	echo $! > "$PIDFILE"
}

start() {
	printf "%s" "Ensuring resolv.conf: "
	if has_nameserver; then
		echo "already present"
		return 0
	fi
	gw="$(default_gateway 2>/dev/null || true)"
	if [ -n "$gw" ] && write_resolv "$gw"; then
		echo "OK ($gw)"
		return 0
	fi
	if [ "${RESOLV_DISABLE_HELPER:-0}" = "1" ]; then
		echo "helper disabled"
		return 0
	fi
	spawn_helper
	echo "waiting"
	return 0
}

stop() {
	printf "%s" "Stopping resolv helper: "
	[ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE" 2>/dev/null)" >/dev/null 2>&1 || true
	rm -f "$PIDFILE"
	echo "OK"
	return 0
}

case "$1" in
	start|stop)
		"$1"
		;;
	restart)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac
