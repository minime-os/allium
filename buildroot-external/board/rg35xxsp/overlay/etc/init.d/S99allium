#!/bin/sh

DAEMON="/mnt/SDCARD/.allium/bin/alliumd"
LOG="/mnt/SDCARD/.allium/logs/alliumd.log"

case "$1" in
	start)
		mkdir -p /mnt/SDCARD/.allium/logs
		if [ -x "$DAEMON" ]; then
			ALLIUM_SD_ROOT=/mnt/SDCARD "$DAEMON" >>"$LOG" 2>&1 &
		else
			echo "missing $DAEMON" >>"$LOG"
		fi
		;;
	stop)
		killall alliumd >/dev/null 2>&1 || true
		;;
	restart)
		"$0" stop
		"$0" start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac
