pkgname=u-boot-rg35xxsp
pkgver=2025.10
pkgrel=6
pkgdesc="RG35xxSP U-Boot artifact wrapper aligned to Alpine u-boot"
arch="aarch64"
url="https://www.denx.de/wiki/U-Boot/"
license="GPL-2.0-or-later OFL-1.1 BSD-2-Clause BSD-3-Clause WITH eCos-exception-2.0 IBM-pibs ISC LGPL-2.0-only LGPL-2.1-only X11"
makedepends="
  arm-trusted-firmware
  bc
  bison
  dtc
  flex
  gawk
  gnutls-dev
  linux-headers
  ncurses-dev
  openssl-dev
  py3-elftools
  py3-setuptools
  python3-dev
  swig
  u-boot-tools
  util-linux-dev
"
source="https://ftp.denx.de/pub/u-boot/u-boot-${pkgver//_/-}.tar.bz2"
builddir="$srcdir/u-boot-${pkgver//_/-}"
options="!check"
_board_root="$startdir/../../board/rg35xxsp"
_board_defconfig="anbernic_rg35xx_h700_defconfig"
_board_name="anbernic_rg35xx_h700"
_artifact_dir="$srcdir/artifacts"
_build_output_dir="$builddir/build/$_board_name"
_bl31="/usr/share/arm-trusted-firmware/sun50i_h616/bl31.bin"
_metadata_dir="/usr/lib/sp/artifacts/u-boot"
_boot_script_source="$srcdir/boot.cmd"

prepare() {
  default_prepare
  [ -f "$_bl31" ] || die "missing Alpine TF-A BL31 artifact: $_bl31"
}

build() {
  mkdir -p "$_artifact_dir" "$_build_output_dir"
  msg "Using Alpine U-Boot source baseline: u-boot-$pkgver-r$pkgrel"
  msg "Using Alpine TF-A package: $(apk info -e -v arm-trusted-firmware 2>/dev/null || echo unknown)"
  msg "Using Alpine TF-A BL31 path: $_bl31"
  cp "$_board_root/boot.cmd" "$_boot_script_source"
  make -C "$builddir" O="$_build_output_dir" "$_board_defconfig"
  cat "$_board_root/uboot.config" >> "$_build_output_dir/.config"
  make -C "$builddir" O="$_build_output_dir" olddefconfig
  make -C "$builddir" O="$_build_output_dir" BL31="$_bl31" all
  mkimage -C none -A arm -T script -d "$_boot_script_source" "$_artifact_dir/boot.scr"
}

package() {
  install -D -m 0644 \
    "$_build_output_dir/u-boot-sunxi-with-spl.bin" \
    "$pkgdir$_metadata_dir/u-boot-sunxi-with-spl.bin"
  install -D -m 0644 \
    "$_artifact_dir/boot.scr" \
    "$pkgdir$_metadata_dir/boot.scr"
  cat > "$pkgdir$_metadata_dir/alpine-source.txt" <<-EOF
    package=u-boot
    package_version=$pkgver-r$pkgrel
    board=$_board_name
    defconfig=$_board_defconfig
    bl31_path=$_bl31
    boot_script=$_boot_script_source
    config_fragment=$_board_root/uboot.config
EOF
}

clean() {
  find "$startdir" -name '.DS_Store' -delete 2>/dev/null || true
  rm -rf "$srcdir" "$pkgdir" "$builddir"
}

sha512sums="
01ac8b2b36bd73b7accc22afd20cf45d08ff8ece6a3d1c426ec90936d1767245add92572cc162500b2160bbc0e2ceed3e111a2a0dd35f8f3a86edbd4fc78753c  u-boot-2025.10.tar.bz2
"
